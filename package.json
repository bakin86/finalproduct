{
  "name": "aurasync-server",
  "version": "1.0.0",
  "description": "AuraSync backend API",
  "type": "module",
  "main": "src/app.js",
  "scripts": {
    "build":      "prisma generate",
    "dev":        "nodemon",
    "start":      "node src/app.js",
    "db:migrate": "prisma migrate deploy",
    "db:push":    "prisma db push",
    "db:generate":"prisma generate",
    "db:studio":  "prisma studio"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@prisma/client":      "^5.22.0",
    "cors":                "^2.8.5",
    "dotenv":              "^16.4.5",
    "express":             "^4.19.2",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken":        "^9.0.2",
    "mariadb":             "^3.3.2",
    "multer":              "^1.4.5-lts.1",
    "socket.io":           "^4.7.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "prisma":  "^5.22.0"
  }
}
